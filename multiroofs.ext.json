{
  "type": "CityJSONExtension",
  "name": "multiroofs",
  "uri": "https://multiroofs.be/myextension.json",
  "version": "0.1.0",
  "versionCityJSON": "2.0",
  "description": "Attributes needed for the MultiRoofs project",
  "extraAttributes": {
    "Building": {
      "+building-function": {
        "type": "string"
      },
      "+building-type": {
        "type": "string",
        "enum": ["Detached", "Semi-detached", "Apartement"]
      },
      "+building-volume": {
        "type": "number"
      },
      "+building-max-height-allowed": {
        "type": ["number", "null"]
      },
      "+building-has-elevator": {
        "type": ["string", "null"],
        "enum": ["yes", "no", null]
      },
      "+building-heritage-status": {
        "type": ["string", "null"]
      },
      "+building-monument-status": {
        "type": ["boolean", "null"]
      },
      "+roof-area": {
        "type": "number"
      },
      "+roof-elevation": {
        "type": "number"
      },
      "+year-construction": {
        "type": "integer"
      },
      "+colours": {
        "type": "object",
        "properties": {
          "social": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "water": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "green": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "energy": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "densification": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "utilities": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "mobility": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "social, water, green, energy, densification, utilities, mobility"
        ],
        "additionalProperties": false
      }
    }
  },
  "extraRootProperties": {},
  "extraSemanticSurfaces": {},
  "extraCityObjects": {}
}
